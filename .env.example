# Database Connection (Neon Cloud or local PostgreSQL)
DATABASE_URL="postgresql://user:password@host:port/db-name?sslmode=require"

# JWT Token Secrets (Generate secure random 64-character hex strings)
ACCESS_TOKEN_SECRET="your_access_token_secret_here"
REFRESH_TOKEN_SECRET="your_refresh_token_secret_here"

# SMTP Email Configuration (For sending emails/verifications)
EMAIL_USER="your_email@gmail.com"
EMAIL_PASS="your_email_app_password"

# AI Integration (Groq API Key)
GROQ_API_KEY="gsk_..."

# Cloudinary Integration (For file/image storage)
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# Redis URL (For background worker queue)
REDIS_URL="redis://127.0.0.1:6379"
